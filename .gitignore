# =============================================================================
# .gitignore — Posit FPGA Project (Vivado 2025.1 / Artix-7)
# =============================================================================

# ─── Vivado generated project directories ────────────────────────────────────
*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
*.srcs/utils_1/
.Xil/

# ─── Vivado project files (regenerated by build.tcl) ─────────────────────────
*.xpr
*.jou
*.log
*.str
*.pb
*.wpc
*.wdf
*.db

# ─── Bitstream and checkpoint files (large binaries) ─────────────────────────
*.bit
*.bin
*.dcp
*.ltx

# ─── Vivado reports — keep hand-collected ones in docs/reports/, ignore auto ─
synth/*.rpt
synth/*.rpx

# ─── Webtalk / telemetry ─────────────────────────────────────────────────────
webtalk*.xml
webtalk*.jou
dfx_runtime.txt

# ─── Simulation outputs ───────────────────────────────────────────────────────
sim/*.out
sim/*.vcd
sim/*.fst
sim/*.lxt
sim/*.wlf
transcript
modelsim.ini
work/

# ─── ILA / VIO / IP cores (regenerate from Vivado IP catalog) ────────────────
*.xci
managed_ip_project/
ip_repo/

# ─── Open-source toolchain outputs ───────────────────────────────────────────
*.json
*.asc
*.blif
*.svf

# ─── OS and editor noise ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ─── Python helper scripts bytecode ──────────────────────────────────────────
__pycache__/
*.pyc
